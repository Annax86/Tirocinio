function sysCall_init()
    camSensor = sim.getObject('.')
    cameraBody = sim.getObject('/Camera')
    droneBase = sim.getObject('/Quadcopter_target')
    
    -- Inizializziamo le variabili per mantenere i valori
    currentTilt = 0
end

function sysCall_sensing()
    -- Riceviamo i comandi da Python
    local tilt = sim.getFloatSignal("cameraTilt") or currentTilt
    
    -- Aggiorniamo i valori correnti
    currentTilt = tilt
    
    -- Otteniamo l'orientamento del drone (per sincronizzare lo Yaw del drone con la camera)
    local dOri = sim.getObjectOrientation(droneBase, sim.handle_world)
    
    -- APPLICAZIONE DEI MOVIMENTI:
    sim.setObjectOrientation(cameraBody, sim.handle_world, {currentTilt, 0, 0})
end
